# Kafka
KAFKA_CLUSTER_ID=your_cluster_id
KAFKA_BOOTSTRAP_SERVERS=master_ip:9092,slave1_ip:9092,slave2_ip:9092

# Spark
SPARK_MASTER=spark://master_ip:7077

# Node
NODE_ID=1
MY_IP=your_ip
MASTER_IP=your_master_ip
SLAVE1_IP=your_slave1_ip
SLAVE2_IP=your_slave2_ip

# GCS
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp_credentials.json
GCS_BUCKET_NAME=your_gcs_bucket_name

# SUMO / OSM
# Optional: defaults to dashboard/backend/app/utils/maps/nghia_do_cut.osm.xml
#SUMO_OSM_FILE=/path/to/nghia_do_cut.osm.xml

# Binary paths (auto-detected at runtime; set only if auto-detection fails)
#SPARK_SUBMIT=/opt/spark/bin/spark-submit
#UVICORN_BIN=/path/to/venv/bin/uvicorn
#NPM_BIN=/path/to/npm
#FRONTEND_DIR=/path/to/dashboard/frontend
