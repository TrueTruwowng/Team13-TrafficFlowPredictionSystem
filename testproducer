import os
import json
import logging
from datetime import datetime
from dotenv import load_dotenv
from utils.api_utils import TrafficWeatherAPI
from utils.kafka_utils import KafkaBroker

# --- CẤU HÌNH LOGGER ---
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[
        logging.FileHandler("debug_kafka.log"), # Lưu vào file để kiểm tra sau
        logging.StreamHandler()                # Hiển thị ra màn hình
    ]
)
logger = logging.getLogger(__name__)

load_dotenv()

def fetch_and_push_traffic(api, kafka, location_name, coor):
    """Hàm xử lý riêng cho dữ liệu giao thông"""
    logger.info(f"📡 Đang lấy dữ liệu GIAO THÔNG cho: {location_name}...")
    try:
        traffic_data = api.get_traffic_flow(coor)
        if traffic_data:
            traffic_data["location_id"] = location_name
            # recordDatetime đại diện cho thời điểm nạp vào hệ thống
            traffic_data["recordDatetime"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            
            kafka.send_to_topic(
                topic="traffic-flow", 
                key=location_name, 
                data=traffic_data
            )
            logger.info(f"✅ [Traffic] Đã gửi message tới hàng chờ cho topic 'traffic-flow'")
            return True
        else:
            logger.warning(f"⚠️ [Traffic] API không trả về dữ liệu cho {location_name}")
    except Exception as e:
        logger.error(f"❌ [Traffic] Lỗi khi xử lý: {str(e)}")
    return False

def fetch_and_push_weather(api, kafka, location_name, lat, lon):
    """Hàm xử lý riêng cho dữ liệu thời tiết"""
    logger.info(f"🌤️ Đang lấy dữ liệu THỜI TIẾT cho: {location_name}...")
    try:
        weather_data = api.get_weather(lat, lon)
        if weather_data:
            weather_data["location_id"] = location_name
            weather_data["recordDatetime"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            
            kafka.send_to_topic(
                topic="weather-data", 
                key=location_name, 
                data=weather_data
            )
            logger.info(f"✅ [Weather] Đã gửi message tới hàng chờ cho topic 'weather-data'")
            return True
        else:
            logger.warning(f"⚠️ [Weather] API không trả về dữ liệu cho {location_name}")
    except Exception as e:
        logger.error(f"❌ [Weather] Lỗi khi xử lý: {str(e)}")
    return False

def main():
    bootstrap_servers = os.getenv("KAFKA_BOOTSTRAP_SERVERS")
    logger.info(f"🛠️ Khởi tạo kết nối tới Kafka: {bootstrap_servers}")
    
    try:
        api = TrafficWeatherAPI(os.getenv("TOMTOM_API_KEY"), os.getenv("OPENWEATHER_API_KEY"))
        kafka = KafkaBroker(bootstrap_servers)
        
        location_name = "CG - TDN"
        lat, lon = "21.035091", "105.793625"
        coor = f"{lat},{lon}"

        traffic_ok = fetch_and_push_traffic(api, kafka, location_name, coor)
        weather_ok = fetch_and_push_weather(api, kafka, location_name, lat, lon)

        if traffic_ok or weather_ok:
            logger.info("⏳ Đang thực hiện flush() để đẩy dữ liệu thực tế lên Broker...")
            kafka.flush()
            logger.info(f"🚀 [SUCCESS] Dữ liệu của '{location_name}' đã bay lên Kafka!")
        
        kafka.close()
    except Exception as e:
        logger.critical(f"💥 LỖI HỆ THỐNG: {str(e)}")

if __name__ == "__main__":
    main()