{
  "title": "Traffic Pipeline Monitoring changed",
  "uid": "traffic-pipeline-v2",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["pipeline", "kafka", "spark"],
  "panels": [

    {
      "id": 1,
      "title": "Process Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "pipeline_process_up",
          "legendFormat": "{{process}}"
        }
      ]
    },

    {
      "id": 2,
      "title": "Process Uptime (giây)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 300 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "pipeline_process_uptime_seconds",
          "legendFormat": "{{process}}"
        }
      ]
    },

    {
      "id": 3,
      "title": "Restart Rate (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(pipeline_restart_total[5m])",
          "legendFormat": "{{process}} restarts/s"
        }
      ]
    },

    {
      "id": 4,
      "title": "Fast Crash Count (cumulative)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "pipeline_fast_crash_total or vector(0)",
          "legendFormat": "{{process}}"
        }
      ]
    },

    {
      "id": 5,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (topic, consumergroup) (kafka_consumergroup_lag)",
          "legendFormat": "{{consumergroup}} / {{topic}}"
        }
      ]
    },

    {
      "id": 6,
      "title": "Kafka Messages/s (produced)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(kafka_topic_partition_current_offset[1m])",
          "legendFormat": "{{topic}} p{{partition}}"
        }
      ]
    },

    {
      "id": 7,
      "title": "Spark — Input Rows/s",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "rowsps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum({__name__=~\"metrics_app_.*_driver_spark_streaming_.*_inputRate_total_Value\"})",
          "legendFormat": "Total Input Rate"
        }
      ]
    },

    {
      "id": 8,
      "title": "Spark — Batch Duration (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "max({__name__=~\"metrics_app_.*_driver_spark_streaming_.*_latency_Value\"})",
          "legendFormat": "Max Batch Latency"
        }
      ]
    }

  ]
}
